rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(uid) {
      return signedIn() && uid == request.auth.uid;
    }

    function validGame(game) {
      return game in ['fifa', 'gta', 'warzone'];
    }

    function safeProfile() {
      return request.resource.data.keys().hasOnly([
        'displayName', 'username', 'mainGame', 'platform', 'region', 'status', 'playStyle',
        'rank', 'availability', 'lookingFor', 'statsSummary', 'bio',
        'psn', 'xbox', 'activision', 'ea', 'discord', 'twitch', 'highlightUrl',
        'avatarUrl', 'avatarPath', 'uid', 'isAnonymous', 'updatedAt'
      ])
      && request.resource.data.displayName is string
      && request.resource.data.displayName.size() <= 40
      && request.resource.data.username is string
      && request.resource.data.username.size() <= 24
      && request.resource.data.username.matches('^[a-z0-9_.]+$')
      && validGame(request.resource.data.mainGame)
      && request.resource.data.platform is string
      && request.resource.data.platform.size() <= 24
      && request.resource.data.region is string
      && request.resource.data.region.size() <= 36
      && request.resource.data.status is string
      && request.resource.data.status.size() <= 24
      && request.resource.data.playStyle is string
      && request.resource.data.playStyle.size() <= 32
      && request.resource.data.rank is string
      && request.resource.data.rank.size() <= 40
      && request.resource.data.availability is string
      && request.resource.data.availability.size() <= 60
      && request.resource.data.lookingFor is string
      && request.resource.data.lookingFor.size() <= 80
      && request.resource.data.statsSummary is string
      && request.resource.data.statsSummary.size() <= 90
      && request.resource.data.bio is string
      && request.resource.data.bio.size() <= 220
      && request.resource.data.psn is string
      && request.resource.data.psn.size() <= 40
      && request.resource.data.xbox is string
      && request.resource.data.xbox.size() <= 40
      && request.resource.data.activision is string
      && request.resource.data.activision.size() <= 40
      && request.resource.data.ea is string
      && request.resource.data.ea.size() <= 40
      && request.resource.data.discord is string
      && request.resource.data.discord.size() <= 40
      && request.resource.data.twitch is string
      && request.resource.data.twitch.size() <= 60
      && request.resource.data.highlightUrl is string
      && request.resource.data.highlightUrl.size() <= 140
      && (
        !request.resource.data.keys().hasAny(['avatarUrl'])
        || (request.resource.data.avatarUrl is string && request.resource.data.avatarUrl.size() <= 500)
      )
      && (
        !request.resource.data.keys().hasAny(['avatarPath'])
        || (request.resource.data.avatarPath is string && request.resource.data.avatarPath.size() <= 160)
      )
      && request.resource.data.uid == request.auth.uid
      && request.resource.data.isAnonymous is bool;
    }

    match /profiles/{uid} {
      allow read: if true;
      allow create, update: if isOwner(uid) && safeProfile();
      allow delete: if isOwner(uid) || isAdmin();
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly([
          'game', 'title', 'body', 'meta', 'ownerUid', 'ownerName', 'createdAt'
        ])
        && request.resource.data.ownerUid == request.auth.uid
        && validGame(request.resource.data.game)
        && request.resource.data.title is string
        && request.resource.data.title.size() <= 80
        && request.resource.data.body is string
        && request.resource.data.body.size() <= 260
        && request.resource.data.meta is string
        && request.resource.data.meta.size() <= 90
        && request.resource.data.ownerName is string
        && request.resource.data.ownerName.size() <= 40;
      allow update, delete: if isAdmin();
    }

    match /messages/{messageId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly([
          'author', 'game', 'text', 'time', 'uid', 'messageType',
          'audioUrl', 'audioPath', 'audioDataUrl', 'audioMimeType', 'audioDuration',
          'createdAt'
        ])
        && request.resource.data.uid == request.auth.uid
        && validGame(request.resource.data.game)
        && request.resource.data.author is string
        && request.resource.data.author.size() <= 40
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 160
        && request.resource.data.time is string
        && request.resource.data.time.size() <= 20
        && request.resource.data.messageType in ['text', 'voice']
        && (
          request.resource.data.messageType == 'text'
          || request.resource.data.keys().hasAny(['audioUrl', 'audioDataUrl'])
        )
        && (
          !request.resource.data.keys().hasAny(['audioUrl'])
          || (request.resource.data.audioUrl is string && request.resource.data.audioUrl.size() <= 500)
        )
        && (
          !request.resource.data.keys().hasAny(['audioPath'])
          || (request.resource.data.audioPath is string && request.resource.data.audioPath.size() <= 180)
        )
        && (
          !request.resource.data.keys().hasAny(['audioDataUrl'])
          || (request.resource.data.audioDataUrl is string
            && request.resource.data.audioDataUrl.size() <= 700000
            && request.resource.data.audioDataUrl.matches('data:audio/.*'))
        )
        && (
          !request.resource.data.keys().hasAny(['audioMimeType'])
          || (request.resource.data.audioMimeType is string && request.resource.data.audioMimeType.matches('audio/.*'))
        )
        && (
          !request.resource.data.keys().hasAny(['audioDuration'])
          || (request.resource.data.audioDuration is number
            && request.resource.data.audioDuration >= 0
            && request.resource.data.audioDuration <= 45)
        );
      allow update, delete: if isAdmin();
    }

    match /squads/{squadId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly([
          'game', 'name', 'need', 'region', 'vibe', 'tags',
          'ownerUid', 'ownerName', 'createdAt'
        ])
        && request.resource.data.ownerUid == request.auth.uid
        && validGame(request.resource.data.game)
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 48
        && request.resource.data.need is string
        && request.resource.data.need.size() <= 60
        && request.resource.data.region is string
        && request.resource.data.region.size() <= 36
        && request.resource.data.vibe is string
        && request.resource.data.vibe.size() <= 40
        && request.resource.data.tags is list
        && request.resource.data.tags.size() <= 4
        && request.resource.data.ownerName is string
        && request.resource.data.ownerName.size() <= 40;
      allow update, delete: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly([
          'game', 'title', 'when', 'spots', 'ownerUid', 'ownerName', 'createdAt'
        ])
        && request.resource.data.ownerUid == request.auth.uid
        && validGame(request.resource.data.game)
        && request.resource.data.title is string
        && request.resource.data.title.size() <= 64
        && request.resource.data.when is string
        && request.resource.data.when.size() <= 40
        && request.resource.data.spots is number
        && request.resource.data.spots >= 1
        && request.resource.data.spots <= 99
        && request.resource.data.ownerName is string
        && request.resource.data.ownerName.size() <= 40;
      allow update, delete: if isAdmin();
    }

    match /postJoins/{joinId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly([
          'postId', 'uid', 'displayName', 'createdAt'
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.postId is string
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() <= 40;
      allow update: if false;
      allow delete: if isOwner(resource.data.uid) || isAdmin();
    }

    match /squadRequests/{requestId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly([
          'squadId', 'uid', 'displayName', 'createdAt'
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.squadId is string
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() <= 40;
      allow update: if false;
      allow delete: if isOwner(resource.data.uid) || isAdmin();
    }

    match /eventRsvps/{rsvpId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly([
          'eventId', 'uid', 'displayName', 'createdAt'
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.eventId is string
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() <= 40;
      allow update: if false;
      allow delete: if isOwner(resource.data.uid) || isAdmin();
    }

    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly([
          'postId', 'title', 'reason', 'uid', 'displayName', 'status', 'createdAt'
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.postId is string
        && request.resource.data.title is string
        && request.resource.data.title.size() <= 80
        && request.resource.data.reason is string
        && request.resource.data.reason.size() <= 120
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() <= 40
        && request.resource.data.status == 'open';
      allow update, delete: if isAdmin();
    }

    match /playerActions/{actionId} {
      allow read: if isOwner(resource.data.uid);
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly([
          'uid', 'targetId', 'targetName', 'game', 'action', 'createdAt'
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.targetId is string
        && request.resource.data.targetId.size() <= 80
        && request.resource.data.targetName is string
        && request.resource.data.targetName.size() <= 40
        && validGame(request.resource.data.game)
        && request.resource.data.action in ['like', 'pass'];
      allow update: if false;
      allow delete: if isOwner(resource.data.uid) || isAdmin();
    }

    match /privateMessages/{messageId} {
      allow read: if signedIn() && request.auth.uid in resource.data.participants;
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly([
          'uid', 'senderName', 'senderUsername', 'targetId', 'targetName', 'targetUsername', 'participants', 'text', 'createdAt'
        ])
        && request.resource.data.uid == request.auth.uid
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && request.resource.data.senderName is string
        && request.resource.data.senderName.size() <= 40
        && request.resource.data.senderUsername is string
        && request.resource.data.senderUsername.size() <= 24
        && request.resource.data.senderUsername.matches('^[a-z0-9_.]+$')
        && request.resource.data.targetId is string
        && request.resource.data.targetId.size() <= 80
        && request.resource.data.targetName is string
        && request.resource.data.targetName.size() <= 40
        && request.resource.data.targetUsername is string
        && request.resource.data.targetUsername.size() <= 24
        && request.resource.data.targetUsername.matches('^[a-z0-9_.]+$')
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 160;
      allow update, delete: if isOwner(resource.data.uid) || isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isOwner(resource.data.uid);
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly([
          'uid', 'title', 'body', 'unread', 'createdAt'
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() <= 64
        && request.resource.data.body is string
        && request.resource.data.body.size() <= 160
        && request.resource.data.unread is bool;
      allow update, delete: if isOwner(resource.data.uid) || isAdmin();
    }

    match /matches/{matchId} {
      allow read: if signedIn() && request.auth.uid in resource.data.participants;
      allow create, update, delete: if false;
    }

    match /emailEvents/{eventId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /admins/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
